#!/usr/bin/env python3
import datetime
import json
import subprocess
import sys
import unicodedata

# Strip emojis and symbol categories from events so they don't break in the TUI
STRIP_CATEGORIES = {"So", "Cs", "Mn"}

year = datetime.date.today().year
year_start = f"{year}-01-01"
year_end = f"{year}-12-31"
gcalcli_cmd = f"gcalcli --nocolor agenda {year_start} {year_end} --nodeclined --details=end --details=url --tsv"

result = subprocess.run(
    [
        "nextmeeting",
        "--max-title-length", "30",
        "--notify-min-before-events", "15",
        "--hour-separator", ":",
        "--today-only",
        "--no-meeting-text", "",
        "--format", "om {minutes_until} min - {title}",
        "--gcalcli-cmdline", gcalcli_cmd,
        "--cache-events-ttl", "1",
        "--waybar",
    ],
    capture_output=True,
    text=True,
)

try:
    data = json.loads(result.stdout)
except json.JSONDecodeError:
    print('{"text": ""}')
    sys.exit(0)

raw_text = data.get("text", "")
clean_text = "".join(c for c in raw_text if unicodedata.category(c) not in STRIP_CATEGORIES).strip()

if clean_text:
    data["text"] = clean_text
    print(json.dumps(data))
else:
    print('{"text": ""}')
